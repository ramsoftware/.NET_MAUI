<ContentPage
    x:Class="BaseDatos.CrearPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Nombre:"/>
            <Entry x:Name="TxtNombre"/>

            <Label Text="Año de lanzamiento:"/>
            <Entry x:Name="TxtAnyo" Keyboard="Numeric"/>

            <Label Text="Plataforma:"/>
            <Picker x:Name="PickerPlataforma"
                    ItemDisplayBinding="{Binding Nombre}"/>

            <Label Text="Género:"/>
            <Picker x:Name="PickerGenero"
                    ItemDisplayBinding="{Binding Nombre}"/>

            <Button Text="Guardar"
                    BackgroundColor="Green"
                    TextColor="White"
                    Clicked="Guardar_Clicked"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>