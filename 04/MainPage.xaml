<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ejemplo.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <!-- Etiqueta -->
            <Label Text="Ingresa tu nombre:" />
            
            <!-- Entrada de texto -->
            <Entry x:Name="UnNombre" />

            <!-- Botón -->
            <Button Text="Presionar" Clicked="CuandoHaceClic" />

            <!-- Salida -->
            <Entry x:Name="LaSalida" IsReadOnly="True"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
