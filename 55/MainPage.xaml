<ContentPage
    x:Class="BaseDatos.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Padding="15">

        <!-- ENCABEZADOS -->
        <Grid ColumnDefinitions="2*,2*,2*,1*"
              Padding="0,10"
              BackgroundColor="#DDD">

            <Label Text="Nombre" FontAttributes="Bold"/>
            <Label Text="Plataforma" Grid.Column="1" FontAttributes="Bold"/>
            <Label Text="Género" Grid.Column="2" FontAttributes="Bold"/>
            <Label Text="Año" Grid.Column="3" FontAttributes="Bold"/>

        </Grid>

        <!-- GRID CON LOS DATOS -->
        <Grid x:Name="GridDatos"
              ColumnDefinitions="2*,2*,2*,1*"
              RowSpacing="6"
              Margin="0,5"/>

        <!-- Botones de paginación -->
        <HorizontalStackLayout HorizontalOptions="Center" Margin="10">

            <Button Text="Inicio" Clicked="IrInicio_Clicked"/>
            <Button Text="Atrás"  Clicked="Atras_Clicked"/>
            <Button Text="Siguiente"  Clicked="Adelante_Clicked"/>
            <Button Text="Final" Clicked="IrFinal_Clicked"/>

        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentPage>